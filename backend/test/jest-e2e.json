/*
 * ===========================================================================
 * Testes E2E (Integração) - Configuração Jest
 * ===========================================================================
 *
 * Configuração específica para testes de integração (end-to-end).
 * Utiliza o diretório ./test como root e busca arquivos .e2e-spec.ts.
 * ===========================================================================
 */
{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  }
}