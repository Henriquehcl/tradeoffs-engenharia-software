# =============================================
# Variáveis de Ambiente - Backend
# =============================================
# Copie este arquivo como .env e preencha os valores

# Banco de Dados PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/desafio_tecnico?schema=public"

# Segredo JWT - utilizado para assinar e verificar tokens
JWT_SECRET="seu-segredo-jwt-super-seguro-aqui"
JWT_EXPIRATION="24h"

# Porta do servidor
PORT=3001
